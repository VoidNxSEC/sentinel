# voidnxlabs — Consolidated Environment Variables
# Copy to .env and fill in secrets. Never commit .env.
# GitHub: github.com/VoidNxSEC

# ──────────────────────────────────────────────
# NATS / Spectre Event Bus (required)
# ──────────────────────────────────────────────
NATS_URL=tls://localhost:4222

# ──────────────────────────────────────────────
# NATS NKey Auth (M3.1 — required for production)
# Generate with: nix run nixpkgs#nkeys -- -gen user
# Store encrypted: sops -e spectre/config/nkeys/<svc>.nk > <svc>.nk.enc
# ──────────────────────────────────────────────
OWASAKA_NKEY_SEED=
AI_AGENT_OS_NKEY_SEED=
PHANTOM_NKEY_SEED=
PHANTOM_SOC_NKEY_SEED=
CEREBRO_NKEY_SEED=
SECURELLM_BRIDGE_NKEY_SEED=

# ──────────────────────────────────────────────
# Phantom API
# ──────────────────────────────────────────────
PHANTOM_PORT=8008

# ──────────────────────────────────────────────
# Spooknix (STT — GPU optional)
# ──────────────────────────────────────────────
# Production bundle: secrets/runtime.env.enc
# MODEL_SIZE=large-v3
# CUDA_VISIBLE_DEVICES=0
# HF_TOKEN=                  # Required for diarization (pyannote)

# ──────────────────────────────────────────────
# Observability
# ──────────────────────────────────────────────
# POSTGRES_PASSWORD=voidnx
# NEO4J_PASSWORD=voidnx
# GRAFANA_PASSWORD=admin

# ──────────────────────────────────────────────
# LLM Providers (securellm-bridge + phantom)
# ──────────────────────────────────────────────
# Production bundle: secrets/runtime.env.enc
# DEEPSEEK_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ──────────────────────────────────────────────
# ml-ops-api
# ──────────────────────────────────────────────
# ML_OPS_PORT=8083
# ML_OPS_BACKEND=local         # local | remote

# SecureLLM Bridge → ml-ops-api routing (M6.3)
# ML_OPS_ENABLED=false         # set true to activate ml-ops provider in bridge
# ML_OPS_API_URL=http://ml-ops-api:8083   # override for local dev: http://localhost:8083

# ──────────────────────────────────────────────
# SecureLLM Bridge (M3.4 — required for production)
# All LLM calls from phantom route through this URL
# ──────────────────────────────────────────────
# Docker: SECURELLM_BRIDGE_URL=http://securellm-bridge:8080
# Local dev (no bridge): leave empty to use direct provider calls
SECURELLM_BRIDGE_URL=http://localhost:8081

# ──────────────────────────────────────────────
# Cerebro
# ──────────────────────────────────────────────
# CEREBRO_PORT=8002

# ──────────────────────────────────────────────
# Container Registry (CI/CD)
# ──────────────────────────────────────────────
GHCR_ORG=VoidNxSEC
